<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_invoice_template_apply_wizard_form" model="ir.ui.view">
        <field name="name">invoice.template.apply.wizard.form</field>
        <field name="model">invoice.template.apply.wizard</field>
        <field name="arch" type="xml">
            <form string="Apply Invoice Template">
                <group>
                    <field name="move_id" invisible="1"/>
                    <field name="company_id" invisible="1"/>
                    <field name="template_id" options="{'no_create': True}"/>
                    <field name="replace_existing"/>
                </group>
                <footer>
                    <button name="action_apply" string="Apply" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
