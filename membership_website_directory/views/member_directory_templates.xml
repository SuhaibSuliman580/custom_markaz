<odoo>
  <!-- LIST PAGE -->
  <template id="member_directory_list" name="Doctor Directory - Active Doctors (Filters + Details)">
    <t t-call="website.layout">
      <section class="py-5">
        <div class="container">

          <div class="text-center mb-4">
            <h1 class="display-6 mb-2">دليل الأطباء</h1>
            <p class="text-muted mb-0">يظهر هنا الأطباء ذوو العضوية الفعّالة فقط</p>
          </div>

          <div class="row justify-content-center mb-4">
            <div class="col-12 col-lg-10">
              <form method="get" action="/members" class="card shadow-sm border-0">
                <div class="card-body">
                  <div class="row g-2 align-items-end">

                    <div class="col-12 col-lg-4">
                      <label class="form-label mb-1 text-muted small">بحث بالاسم</label>
                      <div class="input-group">
                        <span class="input-group-text bg-white">🔎</span>
                        <input class="form-control" type="text" name="q" t-att-value="q" placeholder="مثال: د. أحمد"/>
                      </div>
                    </div>

                    <div class="col-12 col-md-6 col-lg-2">
                      <label class="form-label mb-1 text-muted small">المحافظة</label>
                      <select class="form-select" name="state_id">
                        <option value="">كل المحافظات</option>
                        <t t-foreach="states" t-as="st">
                          <option t-att-value="st.id" t-att-selected="1 if selected_state_id == st.id else None">
                            <t t-esc="st.name"/>
                          </option>
                        </t>
                      </select>
                    </div>

                    <div class="col-12 col-md-6 col-lg-2">
                      <label class="form-label mb-1 text-muted small">المدينة</label>
                      <select class="form-select" name="city">
                        <option value="">كل المدن</option>
                        <t t-foreach="cities" t-as="ct">
                          <option t-att-value="ct" t-att-selected="1 if selected_city == ct else None">
                            <t t-esc="ct"/>
                          </option>
                        </t>
                      </select>
                    </div>

                    
                    <div class="col-12 col-md-6 col-lg-2">
                      <label class="form-label mb-1 text-muted small">الاختصاص</label>
                      <select class="form-select" name="specialty_id">
                        <option value="">كل الاختصاصات</option>
                        <t t-foreach="specialties" t-as="sp">
                          <option t-att-value="sp.id" t-att-selected="1 if selected_specialty_id == sp.id else None">
                            <t t-esc="sp.name"/>
                          </option>
                        </t>
                      </select>
                    </div>

<div class="col-12 col-lg-2 d-grid">
                      <button class="btn btn-primary" type="submit">تطبيق</button>
                    </div>

                  </div>

                  <t t-if="selected_state_id or selected_city or selected_specialty_id or q">
                    <div class="mt-3">
                      <a class="btn btn-sm btn-outline-secondary" href="/members">مسح الفلاتر</a>
                    </div>
                  </t>
                </div>
              </form>
            </div>
          </div>

          <t t-if="not members">
            <div class="alert alert-info text-center py-4">
              لا يوجد أعضاء مطابقين للبحث/الفلاتر الحالية.
            </div>
          </t>

          <div class="row g-3">
            <t t-foreach="members" t-as="m">
              <div class="col-12 col-md-6 col-lg-4">
                <div class="card member-card h-100">
                  <div class="card-body">
                    <div class="d-flex align-items-start justify-content-between">
                      <div class="pe-2">
                        <h5 class="member-name mb-1" t-esc="m.arabic_name or m.name"/>
                        <div class="small text-muted">عضوية فعّالة</div>
                      </div>
                      <div class="rounded-circle bg-light d-flex align-items-center justify-content-center"
                           style="width:44px;height:44px;">
                        <span style="font-size:20px;">👨‍⚕️</span>
                      </div>
                    </div>

                    <hr class="my-3"/>

                    <t t-if="m.medical_specialty_id">
                      <div class="small text-muted mb-2">🩺 <span t-esc="m.medical_specialty_id.name"/></div>
                    </t>

                    <t t-if="m.membership_number">
                      <div class="small text-muted mb-2">رقم العضوية: <span t-esc="m.membership_number"/></div>
                    </t>

                    <t t-set="phone_val" t-value="m.mobile or m.phone"/>
                    <t t-if="phone_val">
                      <div class="member-phone mb-2">📞 <span t-esc="phone_val"/></div>
                    </t>

                    <t t-set="addr_parts" t-value="[]"/>
                    <t t-if="m.street"><t t-set="addr_parts" t-value="addr_parts + [m.street]"/></t>
                    <t t-if="m.city"><t t-set="addr_parts" t-value="addr_parts + [m.city]"/></t>
                    <t t-if="m.state_id"><t t-set="addr_parts" t-value="addr_parts + [m.state_id.name]"/></t>

                    <t t-if="addr_parts">
                      <div class="member-address mb-3">📍 <span t-esc="', '.join(addr_parts)"/></div>
                    </t>

                    <div class="d-grid">
                      <a class="btn btn-outline-primary" t-att-href="'/members/%d' % m.id">تفاصيل</a>
                    </div>

                  </div>
                </div>
              </div>
            </t>
          </div>

          <t t-if="pager">
            <div class="mt-4 d-flex justify-content-center">
              <t t-call="website.pager"/>
            </div>
          </t>
        </div>

      </section>
    </t>
  </template>

  <!-- DETAIL PAGE (RICH) -->
  <template id="member_directory_detail" name="Doctor Directory - Doctor Detail (Rich)">
    <t t-call="website.layout">
      <section class="py-5">
        <div class="container">

          <div class="mb-3">
            <a class="btn btn-sm btn-outline-secondary" href="/members">← رجوع للدليل</a>
          </div>

          <div class="card shadow-sm border-0">
            <div class="card-body p-4">
              <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
                <div>
                  <h2 class="h4 mb-1" t-esc="member.arabic_name or member.name"/>
                  <div class="text-muted">عضوية فعّالة</div>
                </div>
                <div class="rounded-circle bg-light d-flex align-items-center justify-content-center"
                     style="width:72px;height:72px;">
                  <span style="font-size:30px;">👨‍⚕️</span>
                </div>
              </div>

              <hr class="my-4"/>

              <div class="row g-3">

                <!-- Membership Info -->
                <div class="col-12">
                  <div class="p-3 bg-light rounded">
                    <div class="fw-semibold mb-2">معلومات العضوية</div>
                    <div class="row g-2">
                      <div class="col-12 col-md-4">
                        <div class="small text-muted">الحالة</div>
                        <div>فعّالة</div>
                      </div>
                      <div class="col-12 col-md-4">
                        <div class="small text-muted">رقم العضوية</div>
                        <div>
                          <t t-if="member.membership_number"><span t-esc="member.membership_number"/></t>
                          <t t-else=""><span class="text-muted">غير متوفر</span></t>
                        </div>
                      </div>
                      <div class="col-12 col-md-4">
                        <div class="small text-muted">الاختصاص</div>
                        <div>
                          <t t-if="member.medical_specialty_id"><span t-esc="member.medical_specialty_id.name"/></t>
                          <t t-else=""><span class="text-muted">غير متوفر</span></t>
                        </div>
                      </div>

                      <div class="col-12 col-md-4">
                        <div class="small text-muted">تاريخ بداية العضوية</div>
                        <div>
                          <t t-if="member.membership_start_date"><span t-esc="member.membership_start_date"/></t>
                          <t t-else=""><span class="text-muted">غير متوفر</span></t>
                        </div>
                      </div>
                      <div class="col-12 col-md-4">
                        <div class="small text-muted">تاريخ نهاية العضوية</div>
                        <div>
                          <t t-if="member.membership_end_date"><span t-esc="member.membership_end_date"/></t>
                          <t t-else=""><span class="text-muted">غير متوفر</span></t>
                        </div>
                      </div>
                      <div class="col-12 col-md-4">
                        <div class="small text-muted">تاريخ الانتساب</div>
                        <div>
                          <t t-if="member.membership_join_date"><span t-esc="member.membership_join_date"/></t>
                          <t t-else=""><span class="text-muted">غير متوفر</span></t>
                        </div>
                      </div>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Contact -->
                <div class="col-12 col-lg-6">
                  <div class="p-3 bg-light rounded h-100">
                    <div class="fw-semibold mb-2">بيانات التواصل</div>

                    <t t-set="phone_val" t-value="member.mobile or member.phone"/>
                    <div class="d-flex align-items-center mb-2">
                      <div class="me-2">📞</div>
                      <t t-if="phone_val">
                        <a class="text-decoration-none" t-att-href="'tel:%s' % phone_val">
                          <span t-esc="phone_val"/>
                        </a>
                      </t>
                      <t t-else=""><span class="text-muted">غير متوفر</span></t>
                    </div>

                    <div class="d-flex align-items-center mb-2">
                      <div class="me-2">✉️</div>
                      <t t-if="member.email">
                        <a class="text-decoration-none" t-att-href="'mailto:%s' % member.email">
                          <span t-esc="member.email"/>
                        </a>
                      </t>
                      <t t-else=""><span class="text-muted">غير متوفر</span></t>
                    </div>

                    <div class="d-flex align-items-center">
                      <div class="me-2">💼</div>
                      <t t-if="member.function">
                        <span t-esc="member.function"/>
                      </t>
                      <t t-else=""><span class="text-muted">غير متوفر</span></t>
                    </div>

                  </div>
                </div>

                <!-- Address -->
                <div class="col-12 col-lg-6">
                  <div class="p-3 bg-light rounded h-100">
                    <div class="fw-semibold mb-2">العنوان</div>

                    <t t-set="addr_text" t-value="member.practice_location or ''"/>
                    <t t-if="not addr_text">
                      <t t-set="addr_parts" t-value="[]"/>
                      <t t-if="member.street"><t t-set="addr_parts" t-value="addr_parts + [member.street]"/></t>
                      <t t-if="member.street2"><t t-set="addr_parts" t-value="addr_parts + [member.street2]"/></t>
                      <t t-if="member.city"><t t-set="addr_parts" t-value="addr_parts + [member.city]"/></t>
                      <t t-if="member.state_id"><t t-set="addr_parts" t-value="addr_parts + [member.state_id.name]"/></t>
                      <t t-if="member.country_id"><t t-set="addr_parts" t-value="addr_parts + [member.country_id.name]"/></t>
                      <t t-if="addr_parts">
                        <t t-set="addr_text" t-value="', '.join(addr_parts)"/>
                      </t>
                    </t>

                    <t t-if="addr_text">
                      <div class="d-flex align-items-start">
                        <div class="me-2 mt-1">📍</div>
                        <div><span t-esc="addr_text"/></div>
                      </div>
                    </t>
                    <t t-else="">
                      <span class="text-muted">غير متوفر</span>
                    </t>

                    <t t-if="member.website">
                      <div class="mt-3 d-flex align-items-center">
                        <div class="me-2">🌐</div>
                        <a class="text-decoration-none" t-att-href="member.website" target="_blank" rel="noreferrer noopener">
                          <span t-esc="member.website"/>
                        </a>
                      </div>
                    </t>
                  </div>
                </div>                <!-- Experience -->
                <div class="col-12">
                  <div class="p-3 bg-white border rounded">
                    <div class="fw-semibold mb-2">الخبرة والعمل</div>
                    <div class="row g-2">
                      <div class="col-12 col-md-4">
                        <div class="text-muted small">سنوات الخبرة</div>
                        <div>
                          <t t-if="member.years_of_experience"><span t-esc="member.years_of_experience"/></t>
                          <t t-else=""><span class="text-muted">غير متوفر</span></t>
                        </div>
                      </div>
                      <div class="col-12 col-md-4">
                        <div class="text-muted small">مكان العمل</div>
                        <div>
                          <t t-if="member.workplace_name"><span t-esc="member.workplace_name"/></t>
                          <t t-else=""><span class="text-muted">غير متوفر</span></t>
                        </div>
                      </div>
                      <div class="col-12 col-md-4">
                        <div class="text-muted small">نوع مكان العمل</div>
                        <div>
                          <t t-if="member.workplace_type"><span t-esc="member.workplace_type"/></t>
                          <t t-else=""><span class="text-muted">غير متوفر</span></t>
                        </div>
                      </div>

                      <div class="col-12">
                        <div class="text-muted small">عنوان الممارسة</div>
                        <div>
                          <t t-if="member.practice_location"><span t-esc="member.practice_location"/></t>
                          <t t-else=""><span class="text-muted">غير متوفر</span></t>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

              </div>
            </div>
          </div>
      </section>
    </t>
  </template>
</odoo>
