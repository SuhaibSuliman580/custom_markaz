<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_invoice_service_template_tree" model="ir.ui.view">
        <field name="name">invoice.service.template.tree</field>
        <field name="model">invoice.service.template</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_invoice_service_template_form" model="ir.ui.view">
        <field name="name">invoice.service.template.form</field>
        <field name="model">invoice.service.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="note" placeholder="Internal note..."/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Lines">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id"/>
                                    <field name="name"/>
                                    <field name="quantity"/>
                                    <field name="price_unit"/>
                                    <field name="tax_ids" widget="many2many_tags"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_invoice_service_template" model="ir.actions.act_window">
        <field name="name">Invoice Service Templates</field>
        <field name="res_model">invoice.service.template</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_invoice_service_template_root"
              name="Invoice Service Templates"
              parent="account.menu_finance_configuration"
              sequence="95"
              groups="account.group_account_manager"/>

    <menuitem id="menu_invoice_service_template"
              name="Templates"
              parent="menu_invoice_service_template_root"
              action="action_invoice_service_template"
              sequence="1"
              groups="account.group_account_manager"/>
</odoo>
