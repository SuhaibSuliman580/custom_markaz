<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_invoice_template_button" model="ir.ui.view">
        <field name="name">account.move.form.invoice.template.button</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_open_apply_invoice_template_wizard"
                        type="object"
                        string="Load Template"
                        class="btn-secondary"
                        invisible="move_type != 'out_invoice' or state != 'draft'"
                        groups="account.group_account_invoice"/>
            </xpath>
        </field>
    </record>
</odoo>
